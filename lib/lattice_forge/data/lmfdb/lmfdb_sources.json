{
  "source": {
    "title": "LMFDB - The L-functions and modular forms database",
    "url": "https://www.lmfdb.org",
    "api_url": "https://www.lmfdb.org/api/",
    "api_notes": [
      "Query values use type prefixes such as s, i, f, ls, li, lf, py.",
      "Meta-parameters include _format, _fields, _sort, and _delim.",
      "LMFDB documents a maximum of 100 results per list page and an overall API limit around 10000 results."
    ]
  },
  "collections": {
    "mf_newforms": {
      "url": "https://www.lmfdb.org/api/mf_newforms/",
      "role": "classical modular forms / q-expansion coefficient source lane",
      "sample_query": "level=i1&weight=i12&_format=json&_fields=label,level,weight,dim",
      "cmplx_use": "Anchor modular-form references before any McKay/Moonshine coefficient claims are promoted."
    },
    "mf_hecke_traces": {
      "url": "https://www.lmfdb.org/api/mf_hecke_traces/",
      "role": "Hecke trace data for modular-form comparison lanes",
      "sample_query": "_format=json&_fields=label&_offset=0",
      "cmplx_use": "Potential coefficient/trace comparison surface; use only with narrow queries."
    },
    "lfunc_lfunctions": {
      "url": "https://www.lmfdb.org/api/lfunc_lfunctions/",
      "role": "L-function metadata and analytic fingerprint lane",
      "sample_query": "_format=json&_fields=label,degree,conductor&_offset=0",
      "cmplx_use": "Fingerprint registry for future modular/automorphic closures."
    },
    "lat_lattices": {
      "url": "https://www.lmfdb.org/api/lat_lattices/",
      "role": "positive definite lattice database",
      "sample_query": "dim=i24&_format=json&_fields=label,dim,det,level",
      "cmplx_use": "Cross-check 24D lattice landing forms against external lattice records."
    },
    "gps_groups": {
      "url": "https://www.lmfdb.org/api/gps_groups/",
      "role": "abstract group metadata",
      "sample_query": "_format=json&_fields=label,order,tex_name&_offset=0",
      "cmplx_use": "Group identity/factorization reference for finite-group and Moonshine-adjacent claims."
    },
    "gps_conj_classes": {
      "url": "https://www.lmfdb.org/api/gps_conj_classes/",
      "role": "abstract-group conjugacy class data",
      "sample_query": "_format=json&_fields=group,label,order,size&_offset=0",
      "cmplx_use": "Conjugacy-class comparison lane; query only by known group when needed."
    },
    "hecke_orbits": {
      "url": "https://www.lmfdb.org/api/hecke_orbits/",
      "role": "Hecke orbit records",
      "sample_query": "_format=json&_fields=label&_offset=0",
      "cmplx_use": "Orbit-language bridge for modular forms and action tables."
    }
  },
